# MultiBank QA Automation - Environment Configuration
# Copy this file to .env and adjust values as needed

# Base URL for the trading platform
BASE_URL=https://trade.multibank.io

# Optional: Run tests in headed mode (show browser)
# HEADED=false

# Optional: Slow down operations (ms) for debugging
# SLOW_MO=0

# Optional: Browser to run (chromium, firefox, webkit, or all)
# BROWSER=chromium
